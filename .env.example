# ═══════════════════════════════════════════════════════════════
#   TRON — Trusted Runtime Oversight Node
#   Configuration — "Identity Disc Parameters"
# ═══════════════════════════════════════════════════════════════

# REQUIRED — Your Identity Disc (Bearer token for the remote REST API).
# Generate a strong random string: openssl rand -hex 32
TRON_DISC_KEY=

# REQUIRED — OpenClaw's gateway token (used for the graceful stop API call).
# Find this in your OpenClaw config or dashboard.
OPENCLAW_GATEWAY_TOKEN=

# The kill word that triggers DEREZ. Must be the entire message body,
# or prefixed with "!" (e.g. "!DEREZ"). Case-insensitive.
# Default: DEREZ
TRON_KILL_WORD=DEREZ

# Port TRON listens on (replaces OpenClaw's default port).
# Default: 18789
TRON_PORT=18789

# Port OpenClaw was moved to (TRON forwards traffic here).
# Default: 18790
OPENCLAW_PORT=18790

# Port for TRON's remote REST API (HTTPS, Identity Disc required).
# Default: 9999
TRON_API_PORT=9999
